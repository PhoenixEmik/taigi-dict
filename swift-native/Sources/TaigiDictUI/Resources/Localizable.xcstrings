    "aboutAppDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Taigi Dictionary is an offline-first Taiwanese search tool with entries, senses, and examples."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "台语辞典是离线优先的台语查询工具，提供词目、义项与例句检索。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "台語辭典是離線優先的台語查詢工具，提供詞目、義項與例句檢索。"
          }
        }
